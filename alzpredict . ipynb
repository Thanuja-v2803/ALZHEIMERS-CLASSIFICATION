        "import os\n",
        "import random\n",
        "import zipfile\n",
        "\n",
        "def split_and_zip(dataset_zip_path, train_zip_path, test_zip_path, test_ratio=0.1):\n",
        "    \"\"\"\n",
        "    Splits the dataset within a zip file into train and test sets and creates new zip files.\n",
        "\n",
        "    Args:\n",
        "        dataset_zip_path: Path to the original dataset zip file.\n",
        "        train_zip_path: Path to save the train data zip file.\n",
        "        test_zip_path: Path to save the test data zip file.\n",
        "        test_ratio: Proportion of data to use for testing.\n",
        "    \"\"\"\n",
        "\n",
        "    with zipfile.ZipFile(dataset_zip_path, 'r') as dataset_zip, \\\n",
        "         zipfile.ZipFile(train_zip_path, 'w') as train_zip, \\\n",
        "         zipfile.ZipFile(test_zip_path, 'w') as test_zip:\n",
        "\n",
        "        # Get a list of all files within the dataset zip file\n",
        "        all_files = dataset_zip.namelist()\n",
        "\n",
        "        # Filter for files (exclude directories)\n",
        "        all_files = [f for f in all_files if not f.endswith('/')]\n",
        "\n",
        "        # Create a dictionary to group files by class\n",
        "        class_files = {}\n",
        "        for file in all_files:\n",
        "            class_name = os.path.dirname(file)\n",
        "            if class_name not in class_files:\n",
        "                class_files[class_name] = []\n",
        "            class_files[class_name].append(file)\n",
        "\n",
        "        # Iterate through classes and split files\n",
        "        for class_name, files in class_files.items():\n",
        "            random.shuffle(files)\n",
        "\n",
        "            test_count = int(len(files) * test_ratio)\n",
        "            test_files = files[:test_count]\n",
        "            train_files = files[test_count:]\n",
        "\n",
        "            for file in train_files:\n",
        "                # Read file content from the dataset zip file\n",
        "                with dataset_zip.open(file) as f:\n",
        "                    content = f.read()\n",
        "                # Write file content to the train zip file with preserved structure\n",
        "                train_zip.writestr(file, content)\n",
        "\n",
        "            for file in test_files:\n",
        "                # Read file content from the dataset zip file\n",
        "                with dataset_zip.open(file) as f:\n",
        "                    content = f.read()\n",
        "                # Write file content to the test zip file with preserved structure\n",
        "                test_zip.writestr(file, content)\n",
        "\n",
        "\n",
        "# Example usage:\n",
        "dataset_zip_path = \"/content/alz30 (2).zip\"\n",
        "train_zip_path = \"/content/train (1).zip\"\n",
        "test_zip_path = \"/content/test (1).zip\"\n",
        "split_and_zip(dataset_zip_path, train_zip_path, test_zip_path)\n",
        "\n",
        "print(\"Dataset split and zipped successfully!\")"
      ]
